# Google Gemini — AI Trip Planner + post translation
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Optional model override (default: gemini-2.0-flash | premium: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_MODEL_PREMIUM=gemini-2.5-flash

# Firebase Admin — Firestore cache + daily usage (JSON one-line from service account)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
