# Google Gemini — AI Trip Planner + post translation (required for batch translate)
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Local dev URL for batch translate script
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional — required for batch translate API in production
# ADMIN_SCRIPT_KEY=change-me-in-production
# Optional model override (default: gemini-2.0-flash | premium: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_MODEL_PREMIUM=gemini-2.5-flash

# Firebase Admin — Firestore scripts + server cache (service account JSON)
# Option A — path to downloaded key file (recommended for local scripts):
# FIREBASE_SERVICE_ACCOUNT_PATH=./vietnam-insight-service-account.json
# Option B — one-line JSON:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
