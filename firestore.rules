rules_version = '2';
// Dán nội dung này vào Firebase Console → Firestore Database → Rules → Publish
// (hoặc dùng Firebase CLI: firebase deploy --only firestore:rules)

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function prevPostViews() {
      return resource.data.viewCount is int ? resource.data.viewCount : 0;
    }

    function viewCountOnlyBump() {
      return resource.data.status == "approved"
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["viewCount"])
        && request.resource.data.viewCount is int
        && request.resource.data.viewCount == prevPostViews() + 1;
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /posts/{postId} {
      // Đọc: bài đã duyệt công khai; chủ bài đọc được bài của mình (kể cả chờ duyệt); admin đọc tất cả
      allow read: if resource.data.status == "approved"
        || (request.auth != null && request.auth.uid == resource.data.authorId)
        || isAdmin();

      // Đăng bài: user thường chỉ được tạo pending; admin được tạo approved (tự đăng, không cần duyệt)
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid
        && (
          request.resource.data.status == "pending"
          || (request.resource.data.status == "approved" && isAdmin())
        );

      allow update: if isAdmin() || viewCountOnlyBump();
      allow delete: if isAdmin();
    }
  }
}
