rules_version = '2';
// Dán nội dung này vào Firebase Console → Firestore Database → Rules → Publish
// (hoặc dùng Firebase CLI: firebase deploy --only firestore:rules)

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function prevPostViews() {
      return resource.data.keys().hasAny(["viewCount"])
        && (resource.data.viewCount is int || resource.data.viewCount is float)
        ? resource.data.viewCount
        : 0;
    }

    // Chỉ cho phép cộng đúng +1 trên viewCount (increment client), không sửa field khác.
    // Cho cả bài approved (công khai) và pending (chỉ tác giả/admin đọc) — tránh "0 lượt xem" khi bài chưa duyệt.
    // Cho phép int hoặc float vì Firestore/SDK đôi khi thể hiện số khác kiểu; rule `is int` từng chặn update im lặng.
    function viewCountOnlyBump() {
      let prev = prevPostViews();
      let next = request.resource.data.viewCount;
      return (resource.data.status == "approved" || resource.data.status == "pending")
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["viewCount"])
        && (next is int || next is float)
        && next == prev + 1;
    }

    function commentCountBumpOnly() {
      let prev = resource.data.keys().hasAny(["commentCount"]) && resource.data.commentCount is int
        ? resource.data.commentCount
        : 0;
      let next = request.resource.data.commentCount;
      return request.auth != null
        && (resource.data.status == "approved" || resource.data.status == "pending")
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["commentCount"])
        && next is int
        && (next == prev + 1 || next == prev - 1)
        && next >= 0;
    }

    function postData(postId) {
      return get(/databases/$(database)/documents/posts/$(postId)).data;
    }

    function canReadPost(postId) {
      let post = postData(postId);
      return post.status == "approved"
        || (request.auth != null && request.auth.uid == post.authorId)
        || isAdmin();
    }

    function validCommentImages(images) {
      return images is list && images.size() <= 5;
    }

    function validCommentCreate() {
      let data = request.resource.data;
      return request.auth != null
        && data.userId == request.auth.uid
        && data.postId is string
        && canReadPost(data.postId)
        && data.content is string
        && data.content.size() <= 2000
        && (data.content.size() > 0 || data.images.size() > 0)
        && validCommentImages(data.images)
        && data.likeCount == 0
        && data.replyCount == 0
        && data.isEdited == false
        && data.username is string
        && data.userAvatar is string
        && (data.parentId == null || data.parentId is string)
        && (
          !data.keys().hasAny(["replyToUserId"])
          || data.replyToUserId == null
          || data.replyToUserId is string
        )
        && (
          !data.keys().hasAny(["replyToUsername"])
          || data.replyToUsername == null
          || data.replyToUsername is string
        );
    }

    function authorCommentEditOnly() {
      return request.auth != null
        && request.auth.uid == resource.data.userId
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["content", "images", "updatedAt", "isEdited"])
        && request.resource.data.content is string
        && request.resource.data.content.size() <= 2000
        && (request.resource.data.content.size() > 0 || request.resource.data.images.size() > 0)
        && validCommentImages(request.resource.data.images)
        && request.resource.data.isEdited == true;
    }

    function likeCountBumpOnly() {
      let prev = resource.data.likeCount is int ? resource.data.likeCount : 0;
      let next = request.resource.data.likeCount;
      return request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["likeCount"])
        && next is int
        && (next == prev + 1 || next == prev - 1)
        && next >= 0;
    }

    function replyCountBumpOnly() {
      let prev = resource.data.replyCount is int ? resource.data.replyCount : 0;
      let next = request.resource.data.replyCount;
      return request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["replyCount"])
        && next is int
        && (next == prev + 1 || next == prev - 1)
        && next >= 0;
    }

    match /users/{userId} {
      // Public read — display name + avatar for comments, posts, navbar
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /posts/{postId} {
      // Đọc: bài đã duyệt công khai; chủ bài đọc được bài của mình (kể cả chờ duyệt); admin đọc tất cả
      allow read: if resource.data.status == "approved"
        || (request.auth != null && request.auth.uid == resource.data.authorId)
        || isAdmin();

      // Đăng bài: user thường chỉ được tạo pending; admin được tạo approved (tự đăng, không cần duyệt)
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid
        && (
          request.resource.data.status == "pending"
          || (request.resource.data.status == "approved" && isAdmin())
        );

      allow update: if isAdmin()
        || viewCountOnlyBump()
        || commentCountBumpOnly()
        || (request.auth != null
          && request.auth.uid == resource.data.authorId
          && request.resource.data.authorId == resource.data.authorId);

      allow delete: if isAdmin()
        || (request.auth != null && request.auth.uid == resource.data.authorId);
    }

    match /comments/{commentId} {
      allow read: if canReadPost(resource.data.postId);

      allow create: if validCommentCreate();

      allow update: if isAdmin()
        || authorCommentEditOnly()
        || likeCountBumpOnly()
        || replyCountBumpOnly();

      allow delete: if isAdmin()
        || (request.auth != null && request.auth.uid == resource.data.userId);
    }

    match /commentLikes/{likeId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.commentId is string
        && request.resource.data.postId is string
        && canReadPost(request.resource.data.postId);
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    match /commentReports/{reportId} {
      allow read: if isAdmin();
      allow create: if request.auth != null
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.commentId is string
        && request.resource.data.postId is string
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 500
        && request.resource.data.status == "pending";
      allow update, delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && isAdmin();
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["read"]);
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /saved_itineraries/{itineraryId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // AI Trip Planner — server-only via Admin SDK
    match /trip_plan_cache/{cacheId} {
      allow read, write: if false;
    }

    match /planner_daily_usage/{usageId} {
      allow read, write: if false;
    }

    match /food_analytics/{eventId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.event in ['food_save', 'trip_add', 'ai_generation'];
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if false;
    }

    match /translations/{cacheId} {
      allow read, write: if false;
    }
  }
}
